# Docker Compose reads this file name by default.
# Copy to .env on the NAS before running docker compose.

# Deployment
PORTAL_IMAGE=ghcr.io/your-github-user/your-repo:latest
DB_CONTAINER_NAME=household-db
PORTAL_CONTAINER_NAME=household-portal
TUNNEL_CONTAINER_NAME=household-tunnel

# Database
DB_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://portal:replace-with-a-strong-db-password@db:5432/portal

# Auth
IRON_SESSION_SECRET=replace-with-at-least-32-random-characters
PRIMARY_USER_PIN=replace-with-primary-8-digit-pin
SECONDARY_USER_PIN=replace-with-secondary-8-digit-pin

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# Cron
CRON_SECRET=replace-with-a-random-cron-secret

# Cloudflare Tunnel
CLOUDFLARE_TOKEN=your-tunnel-token
